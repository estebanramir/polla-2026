generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  username          String             @unique
  displayName       String
  passwordHash      String
  isAdmin           Boolean            @default(false)
  createdAt         DateTime           @default(now())
  pointsAdjustment  Int                @default(0) // ajuste manual de puntos (admin)
  badge             String? // etiqueta visible junto al nombre
  predictions       Prediction[]
  awardPrediction   AwardPrediction?
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id          String   @id // código FIFA de 3 letras, ej. "MEX"
  name        String // nombre en español, ej. "México"
  flagCode    String // código ISO-2 para flagcdn, ej. "mx"
  group       String? // "A".."L", null para placeholders
  homeMatches Match[]  @relation("homeTeam")
  awayMatches Match[]  @relation("awayTeam")
  players     Player[]
}

model Player {
  id       String @id // id de ESPN
  name     String
  position String // G | D | M | F
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Match {
  id          Int          @id // número oficial de partido FIFA, 1..104
  stage       String // GROUP | R32 | R16 | QF | SF | THIRD | FINAL
  group       String? // "A".."L" solo en fase de grupos
  kickoff     DateTime
  venue       String
  homeTeamId  String?
  awayTeamId  String?
  homeTeam    Team?        @relation("homeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?        @relation("awayTeam", fields: [awayTeamId], references: [id])
  // etiquetas para slots de eliminatorias aún sin definir, ej. "1A", "2B", "3C/E/F/H/I", "W89"
  homeSlot    String?
  awaySlot    String?
  homeScore   Int?
  awayScore   Int?
  // ganador en eliminatorias cuando hay penales (el marcador puede ser empate)
  winnerId    String?
  predictions Prediction[]
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   Int
  homeScore Int
  awayScore Int
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model AwardPrediction {
  id         String   @id @default(cuid())
  userId     String   @unique
  topScorer  String? // nombre del goleador elegido
  bestKeeper String? // nombre del arquero elegido
  champion   String? // id de equipo campeón elegido
  runnerUp   String? // id de equipo subcampeón elegido
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Valores reales definidos por el admin al final del torneo
model Setting {
  key   String @id // "topScorer" | "bestKeeper" | "awardsLocked"
  value String
}
